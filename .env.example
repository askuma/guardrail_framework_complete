# ──────────────────────────────────────────────────────────────────────────────
# Guardrail Framework — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Clients must pass one of these in the X-API-Key header.
# If unset, a random ephemeral key is generated at startup and printed to logs.
GUARDRAIL_API_KEYS=change-me-key-1,change-me-key-2

# Set to "false" to disable auth entirely (development only).
GUARDRAIL_AUTH_ENABLED=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all.
# Tighten this in production.
GUARDRAIL_CORS_ORIGINS=https://your-app.example.com

# ── Persistence ───────────────────────────────────────────────────────────────
# SQLAlchemy database URL.
# SQLite (default, single-process only):
GUARDRAIL_DB_URL=sqlite:///guardrail.db
# PostgreSQL (recommended for production):
# GUARDRAIL_DB_URL=postgresql://user:password@host:5432/guardrail

# ── Backend API keys ──────────────────────────────────────────────────────────
# Required to use the Lakera Guard backend.
LAKERA_GUARD_API_KEY=

# Required to use the GA Guard backend (set to your endpoint).
GA_GUARD_API_URL=
GA_GUARD_API_KEY=

# ── ESCALATE action ───────────────────────────────────────────────────────────
# HTTP endpoint that receives violation payloads as JSON POST.
GUARDRAIL_ESCALATION_WEBHOOK_URL=https://hooks.example.com/guardrail-alerts

# SMTP settings for escalation emails (all optional).
GUARDRAIL_SMTP_HOST=smtp.example.com
GUARDRAIL_SMTP_PORT=587
GUARDRAIL_SMTP_USER=alerts@example.com
GUARDRAIL_SMTP_PASS=
GUARDRAIL_SMTP_FROM=guardrail-noreply@example.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
