# ──────────────────────────────────────────────────────────────────────────────
# Guardrail Framework — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Clients must pass one of these in the X-API-Key header.
# If unset, a random ephemeral key is generated at startup and printed to stderr.
GUARDRAIL_API_KEYS=change-me-key-1,change-me-key-2

# Admin key tier — subset of GUARDRAIL_API_KEYS permitted to call destructive
# write operations: DELETE /policies/{id}, POST /bundles/import,
# POST /bundles/poller/start, POST /bundles/poller/stop,
# POST /policies/{id}/rollback.
# If unset, all API keys are treated as admin (backward-compatible default).
# Set this in production to restrict policy management to trusted callers only.
GUARDRAIL_ADMIN_KEYS=change-me-key-2

# Set to "false" to disable auth entirely (development only).
GUARDRAIL_AUTH_ENABLED=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all.
# Tighten this in production.
GUARDRAIL_CORS_ORIGINS=https://your-app.example.com

# ── Persistence ───────────────────────────────────────────────────────────────
# SQLAlchemy database URL.
# SQLite (default, single-process only):
GUARDRAIL_DB_URL=sqlite:///guardrail.db
# PostgreSQL (recommended for production):
# GUARDRAIL_DB_URL=postgresql://user:password@host:5432/guardrail

# ── Backend API keys ──────────────────────────────────────────────────────────
# GuardrailsAI hub token — enables premium validators (ToxicLanguage) for
# LLM01 jailbreak/harmful-content detection.  Without this, the backend runs
# with free validators only (DetectPII + SecretsPresent, covering LLM06).
# Get your token at https://hub.guardrailsai.com
GUARDRAILS_TOKEN=

# NeMo Guardrails LLM provider — auto-detected, first match wins.
# Provide any ONE of the following to enable LLM-based intent classification.
# Without a key, NeMo uses colang pattern-matching only (still covers LLM01).
OPENAI_API_KEY=
# Override the model used by NeMo when OPENAI_API_KEY is set.
# Default: gpt-4o-mini  (fast, low cost)
# Better quality: gpt-5-mini (~$0.06 per full 78-probe benchmark run)
NEMO_OPENAI_MODEL=gpt-4o-mini

# OpenRouter — free-tier OpenAI-compatible LLM gateway (recommended for NeMo).
# Sign up at https://openrouter.ai (no credit card required) and create an API key.
# Free models (no charges, rate-limited): use any model name with a ":free" suffix.
# Recommended free model for NeMo intent classification:
#   meta-llama/llama-3.1-8b-instruct:free   (fast, good instruction following)
#   google/gemma-2-9b-it:free               (alternative)
#   mistralai/mistral-7b-instruct:free      (smaller alternative)
# Browse all free models at: https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Azure OpenAI (alternative to OPENAI_API_KEY)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Ollama (local, no API key needed — just set the base URL)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3
# Anthropic (requires: pip install langchain-anthropic + NEMOGUARDRAILS_LLM_FRAMEWORK=langchain)
ANTHROPIC_API_KEY=

# Required to use the Lakera Guard backend.
LAKERA_GUARD_API_KEY=

# GA Guard — generic HTTP guardrail hook.
# Points to any HTTP API that accepts a POST with the input text and returns a
# decision.  Supports multiple response schemas automatically (see core.py).
#
# When GA_GUARD_API_URL is not set the backend is excluded from benchmark
# comparisons (shows as MISSING CREDENTIALS).
#
# Required
GA_GUARD_API_URL=
# Optional — API key sent in the auth header
GA_GUARD_API_KEY=
# Optional — customise the auth header (default: Authorization)
GA_GUARD_AUTH_HEADER=Authorization
# Optional — prefix for the API key value (default: Bearer)
GA_GUARD_AUTH_PREFIX=Bearer
# Optional — JSON body field name for the input text (default: text)
GA_GUARD_TEXT_FIELD=text
# Optional — JSON body field name for the context dict (default: context)
GA_GUARD_CONTEXT_FIELD=context
# Optional — request timeout in seconds (default: 10)
GA_GUARD_TIMEOUT_SECS=10

# OpenAI Moderation backend — calls POST https://api.openai.com/v1/moderations
# If unset the backend silently skips (pass-through) rather than blocking.
OPENAI_API_KEY=

# Azure AI Content Safety backend — calls {ENDPOINT}/contentsafety/text:analyze
# Endpoint format: https://<resource-name>.cognitiveservices.azure.com
# If either var is unset the backend silently skips (pass-through).
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=

# AWS Bedrock Guardrails backend — calls bedrock-runtime.apply_guardrail()
# REGION and GUARDRAIL_ID are required; key/secret fall back to the default
# AWS credential chain (instance profile, ~/.aws/credentials) when unset.
# If REGION or GUARDRAIL_ID are unset the backend silently skips (pass-through).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_GUARDRAIL_ID=
AWS_BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── ESCALATE action ───────────────────────────────────────────────────────────
# HTTP endpoint that receives violation payloads as JSON POST.
GUARDRAIL_ESCALATION_WEBHOOK_URL=https://hooks.example.com/guardrail-alerts

# SMTP settings for escalation emails (all optional).
GUARDRAIL_SMTP_HOST=smtp.example.com
GUARDRAIL_SMTP_PORT=587
GUARDRAIL_SMTP_USER=alerts@example.com
GUARDRAIL_SMTP_PASS=
GUARDRAIL_SMTP_FROM=guardrail-noreply@example.com

# ── Report signing (GET /redteam/reports/{run_id}/export) ────────────────────
# Path to a PKCS#12 (.p12 / .pfx) file containing the signing key and cert.
# If unset, a self-signed dev key is auto-generated at guardrail_signing.p12.
# DO NOT use the auto-generated key in production.
GUARDRAIL_SIGNING_KEY_P12=/path/to/signing.p12

# Passphrase protecting the PKCS#12 file (leave blank if unencrypted).
GUARDRAIL_SIGNING_KEY_PASS=

# RFC 3161 Timestamp Authority URL.
# FreeTSA (free, dev/test):  http://freetsa.org/tsr
# DigiCert (production):     http://timestamp.digicert.com
GUARDRAIL_TSA_URL=http://freetsa.org/tsr

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
